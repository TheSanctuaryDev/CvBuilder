@page
@model CvBuilderApp.Pages.PricingModel
@{
}
<section class="offers-section">

    <div class="offers-header">
        <h1>Choisissez votre <span>offre</span></h1>
        <p>Tarifs simples, sans frais cachés</p>
    </div>

    <div class="offers-grid">

        <!-- GRATUIT -->
        <div class="offer-card free">
            <h3>Gratuit</h3>
            <h2>0 FCFA</h2>

            <ul>
                <li>✔ 2 modèles</li>
                <li>✔ IA limitée</li>
                <li>✔ Export PDF simple</li>
            </ul>

            <a href="/CvTemplate" class="btn btn-ghost">Commencer gratuitement</a>
        </div>

        <!-- PREMIUM -->
        <div class="offer-card premium">
            <div class="badge">Meilleure offre</div>

            <h3>Premium</h3>
            <h2>1000 FCFA</h2>

            <ul>
                <li>✔ Modèles professionnels</li>
                <li>✔ IA illimitée</li>
                <li>✔ Export PDF haute définition</li>
            </ul>

            <a href="/CvTemplate" class="btn btn-primary">Passer en Premium</a>
        </div>

    </div>

</section>
@page
@model IndexModel
@{
    ViewData["Title"] = "Accueil";
}
<section class="hero-section">
    <div class="hero-content">

        <div class="hero-badge">Créez des CV plus intelligents</div>

        <h1>
            Créez votre <span>CV professionnel</span><br />
            en quelques minutes
        </h1>

        <p>
            Créez des CV élégants avec un design moderne.
            Simple, rapide et professionnel.
        </p>

        <div class="hero-buttons">
            <a href="/CvTemplate" class="btn btn-primary">Créer un CV →</a>
        </div>

    </div>
</section>

<section class="cv-preview">

    <div class="preview-header">
        <h2>Découvrez à quoi peut ressembler <span>votre CV</span></h2>
        <p>Un design épuré, moderne et professionnel prêt en quelques minutes.</p>
    </div>

    <div class="cv-mockup">
        <img src="/templates/premium/_mod-15/preview.jpg" alt="Aperçu du CV" class="cv-image">
    </div>
</section>

<section class="features-section">

    <div class="features-header">
        <h2>Pourquoi choisir <span>TheCvBuilder</span> ?</h2>
        <p>Une façon plus intelligente de créer des CV professionnels.</p>
    </div>

    <div class="features-grid">

        <div class="feature-card">
            <div class="icon">⚡</div>
            <h3>Rapide</h3>
            <p>Créez votre CV en quelques minutes grâce à un processus simple et fluide.</p>
        </div>

        <div class="feature-card">
            <div class="icon">🧠</div>
            <h3>IA intégrée</h3>
            <p>Une IA intelligente vous aide à rédiger un meilleur contenu et à optimiser votre CV.</p>
        </div>

        <div class="feature-card">
            <div class="icon">🎨</div>
            <h3>Design professionnel</h3>
            <p>Des modèles de CV modernes, épurés et appréciés des recruteurs.</p>
        </div>

    </div>

</section>

<section class="cta-section">

    <div class="cta-card">

        <h2>Prêt à créer votre <span>CV professionnel</span> ?</h2>

        <p>
            Rejoignez des milliers d'utilisateurs qui créent des CV modernes en quelques minutes.
        </p>

        <div class="cta-buttons">
            <a href="/CvTemplate" class="btn btn-primary">Commencer maintenant</a>
            <a href="/Pricing" class="btn btn-ghost">Voir les tarifs</a>
        </div>

    </div>

</section>
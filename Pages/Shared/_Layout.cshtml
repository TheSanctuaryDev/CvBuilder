<!DOCTYPE html>
<html lang="fr">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P0LKDJH4ZD"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-P0LKDJH4ZD');
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TheCvBuilder</title>
    <script type="importmap"></script>

    @* --- PWA --- *@
    <link rel="manifest" href="/site.webmanifest">
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <meta name="theme-color" content="#c9a84c">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="TheCvBuilder">

    @* --- FONTS ÉLÉGANTES --- *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CvBuilderApp.styles.css" asp-append-version="true" />

    <style>
        /* ── FONTS ── */
        body {
        font-family: 'DM Sans', -apple-system, sans-serif;
        }

        h1, h2, h3, .navbar-brand {
        font-family: 'Playfair Display', Georgia, serif;
        }

        /* ── NAVBAR CORRIGÉE ── */
        .navbar {
        background: rgba(15, 15, 15, 0.75) !important;
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border-bottom: 1px solid rgba(255,255,255,0.08) !important;
        padding: 5px 0;
        }

        .navbar-brand {
        /* color: #ffffff !important; */
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.3px;
        text-decoration: none;
        }

        .navbar-brand::after {
        content: " ●";
        color: #C9A95C;
        font-size: 0.6rem;
        vertical-align: middle;
        }

        .nav-link {
        color: rgba(255,255,255,0.6) !important;
        font-weight: 500;
        font-size: 0.9rem;
        padding: 6px 14px !important;
        border-radius: 999px;
        transition: all 0.25s ease;
        }

        .nav-link:hover {
        color: #ffffff !important;
        background: rgba(255,255,255,0.07);
        }

        /* Lien actif */
        .nav-link.active {
        color: #C9A95C !important;
        }

        /* Toggler mobile */
        .navbar-toggler {
        border: 1px solid rgba(255,255,255,0.2) !important;
        padding: 10px 7px;
        }

        .navbar-toggler-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='black' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
        }

        /* ── FOOTER CORRIGÉ ── */
        .footer {
        background: transparent !important;
        border-top: 1px solid rgba(255,255,255,0.08) !important;
        color: rgba(255,255,255,0.4) !important;
        padding: 28px 0;
        text-align: center;
        font-size: 0.85rem;
        }

        .footer a {
        color: #C9A95C !important;
        text-decoration: none;
        transition: opacity 0.2s;
        }

        .footer a:hover {
        opacity: 0.75;
        }

        /* Ligne dorée décorative au-dessus du footer */
        .footer::before {
        content: '';
        display: block;
        width: 60px;
        height: 2px;
        background: linear-gradient(90deg, transparent, #C9A95C, transparent);
        margin: 0 auto 20px;
        }
 
        /* ── ESPACE SOUS LA NAVBAR ── */
        main {
        padding-top: 25px !important;
        }
        .container{
        padding-top: 25px !important;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">TheCvBuilder</a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Basculer la navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/CvTemplate">Créer un CV</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Pricing">Tarifs</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            &copy; 2026 — TheCvBuilder by TheSanctuaryDev &nbsp;·&nbsp;
            <a asp-area="" asp-page="/Privacy">Confidentialité & Contact</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* --- Service Worker PWA --- *@
    <script>
        if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
        navigator.serviceWorker.register('/sw.js')
        .then(reg => console.log('✅ SW enregistré:', reg.scope))
        .catch(err => console.log('❌ SW erreur:', err));
        });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
